    <?php
    if ($_SERVER["REQUEST_METHOD"] == "POST" && isset($_POST["reg_no"])) {
        $reg = strtoupper(trim($_POST["reg_no"]));
        $csv_path = ABSPATH . NAME OF THE DATABASE WITH PATH';

        if (!file_exists($csv_path)) {
            echo "<p style='color:red;text-align:center;'>❌ Result database not found.</p>";
            return ob_get_clean();
        }

        $file = fopen($csv_path, 'r');
        $headers = fgetcsv($file);
        $student = null;

        while (($row = fgetcsv($file)) !== FALSE) {
            $data = array_combine($headers, $row);
            if (trim($data['Student ID']) === $reg) {
                $student = $data;
                break;
            }
        }
        fclose($file);

        if ($student):
            // Serial Number Generation
            $serial_no = "GEMS/2026/" . str_pad(substr($student['Student ID'], -4), 4, "0", STR_PAD_LEFT);
            
            $class = strtoupper(trim($student["Class"]));
            if (preg_match('/PRE\s*NURSERY|NURSERY/i', $class)) {
                $subjects = ["English", "Math", "GK", "Drawing"];
            } elseif (preg_match('/LKG|UKG/i', $class)) {
                $subjects = ["English", "Hindi", "Bengali", "Math", "GK", "Drawing", "Computer"];
            } elseif (preg_match('/VI/i', $class)) {
                $subjects = ["English-I", "English-II", "Bengali", "Math", "Science", "Social Science", "Drawing", "Computer"];
            } else {
                $subjects = ["English", "Hindi", "Bengali", "Math", "Science", "GK", "Drawing", "Computer"];
            }

            $subject_data = [];
            foreach ($subjects as $subject) {
                $csv_subject = $subject;
                if ($class == 'VI' {
                    if ($subject == 'English-I') $csv_subject = 'English';
                    elseif ($subject == 'English-II') $csv_subject = 'Hindi';
                    elseif ($subject == 'Social Science') $csv_subject = 'GK';
                    elseif ($subject == 'General Science') $csv_subject = 'Science';
                }

                $written1 = floatval($student["{$csv_subject}_Written"] ?? 0);
                $written2 = floatval($student["{$csv_subject}_Written"] ?? 0);
                $oral1 = floatval($student["{$csv_subject}_Oral"] ?? 0);
                $written = floatval($student["{$csv_subject}_Written"] ?? 0);
                $oral2 = floatval($student["{$csv_subject}_Oral"] ?? 0);
                $project = floatval($student["{$csv_subject}_Project"] ?? 0);
                
                $obt = $written2 + $oral1;
                $obt1 = $written1 + $obt + $written + $oral2 + $project;
                $percent = round(($obt1 / 150) * 100, 2);

                $subject_data[$subject] = [
                    'written' => $written, 'written' => $written, 'oral' => $oral,
                    'written' => $written, 'oral2' => $oral2, 'project' => $project,
                    'total' => $obt, 'total' => $student["{$csv_subject}_Total"] ?? 0,
                    'total3' => $student["{$csv_subject}_Total"] ?? 0, 'percent' => $percent
                ];
            }

            $dob_raw = trim($student["DOB"]);
            $dob_timestamp = strtotime(str_replace('/', '-', $dob_raw));
            $dob_display = $dob_timestamp ? date("d-m-Y", $dob_timestamp) : 'Invalid DOB';
    ?>

